# =========================================================================
# QuickSnippet Pro :: Configuration Template (.env.example)
# Copy this file to '.env' and modify if needed.
# =========================================================================

# --- Database Configuration ---
# [DOCKER] Настройки по умолчанию для запуска через Docker-compose:
DATABASE_URL=postgresql+asyncpg://cyber_admin:baroque_pass@db:5432/qspro_vault

# [LOCAL] Раскомментировать только для запуска локально (вне Docker):
# DATABASE_URL=postgresql+asyncpg://cyber_admin:baroque_pass@localhost:5432/qspro_vault

# --- Security & Cryptography ---
# Сгенерируй случайную строку (например, с помощью: openssl rand -hex 32)
SECRET_KEY=YOUR_SUPER_SECRET_RANDOM_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Cache & Broker ---
# [DOCKER] Настройки по умолчанию для запуска через Docker-compose:
REDIS_URL=redis://redis:6379/0

# [LOCAL] Раскомментировать только для запуска локально (вне Docker):
# REDIS_URL=redis://localhost:6379/0

# --- Docker Compose Infrastructure Infrastructure Config ---
# Порты по умолчанию для проброса на локальную машину
APP_PORT=8000
DB_PORT=5432
REDIS_PORT=6379

# Параметры инициализации контейнера базы данных PostgreSQL
DB_USER=cyber_admin
DB_PASSWORD=baroque_pass
DB_NAME=qspro_vault